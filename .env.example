# Supabase — https://supabase.com/dashboard/project/_/settings/api
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# PostHog — https://app.posthog.com/project/settings
VITE_POSTHOG_KEY=phc_your_key_here
VITE_POSTHOG_HOST=https://app.posthog.com

# Stripe — set VITE_STRIPE_ENABLED=true to activate checkout
# WARNING: VITE_STRIPE_ENABLED is a compile-time flag — changing it requires a full rebuild + redeploy
VITE_STRIPE_ENABLED=false
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...

# App URL (for Stripe redirect)
VITE_APP_URL=http://localhost:5173

# ── Supabase Edge Functions secrets (set via: supabase secrets set KEY=val) ──
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_ID=price_...
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
